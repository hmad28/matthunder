# Application
APP_NAME=matthunder
APP_VERSION=2.0.0
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars

# Database - SQLite for local native runs; PostgreSQL can be configured externally.
DATABASE_URL=sqlite+aiosqlite:///./matthunder.db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# Redis - optional for queue-backed workers.
REDIS_URL=

# Celery - optional; empty values use local FastAPI background tasks.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# CORS
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:3010","http://127.0.0.1:3010","http://localhost:8000","http://127.0.0.1:8000","http://localhost:8010","http://127.0.0.1:8010"]

# AI Providers (BYOK - Bring Your Own Key)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...

# Acunetix Integration
# ACUNETIX_URL=https://localhost:3443
# ACUNETIX_API_KEY=your_api_key
# ACUNETIX_VERIFY_SSL=false

# Scanner Configuration
KATANA_LIMIT=20
SCAN_SPEED=standard
SCAN_TIMEOUT=3600
